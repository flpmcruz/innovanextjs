# Google reCAPTCHA v3
# Get keys at: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_KEY=   # Site key (public, exposed to browser)
RECAPTCHA_KEY=               # Secret key (server-side verification)

# SMTP Email (Nodemailer)
SMTP_HOST=                   # e.g. smtp.gmail.com, smtp.hostinger.com
SMTP_EMAIL=                  # Sender email address
SMTP_PASSWORD=               # Email password or app password
